                                <div class="wonder-header">
                                    <div class="wonder-badge">DECEMBER 31, 2012</div>
                                    <h3>Tornado of God Appears</h3>
                                </div>
                                <div class="wonder-media">
                                    <img src="media/fb8ed713d33b38d22977f9588c81b464.svg" class="svg-img" id="e_133" alt="Tornado of God">
                                </div>
                                <p class="wonder-description">The Mightiest Prophet calls down the tornado revealing God's Glory</p>
                                <span class="wonder-location">📍 Kisumu, Kenya</span>
                            </div> -->
                            <div class="carousel-slide">
                                <div class="wonder-header">
                                    <div class="wonder-badge">TRANSFIGURATION</div>
                                    <h3>The Transfiguration of the Prophet</h3>
                                </div>
                                <div class="wonder-media">
                                    <img src="https://live-tag.creatopy.net/designs/0r3qgl0/embed/standard/media/793c23459231818d0081239ecbbd4a16.jpg"
                                         srcset="https://live-tag.creatopy.net/designs/0r3qgl0/embed/standard/media/793c23459231818d0081239ecbbd4a162x.jpg 2x"
                                         alt="Transfiguration" class="wonder-image">
                                </div>
                                <p class="wonder-description">The Glory of the LORD manifested upon His servant</p>
                                <span class="wonder-location">📍 Nakuru, Kenya</span>
                            </div>
                        </div>
                        </div>
                        <button class="carousel-btn prev" onclick="moveCarousel(-1)">‹</button>
                        <button class="carousel-btn next" onclick="moveCarousel(1)">›</button>
                    </div>
                    <div class="carousel-dots"></div>
                </div>
            </div>
        </div>
    </section>

