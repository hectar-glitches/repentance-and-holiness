                                <div class="wonder-header">
                                    <div class="wonder-badge">PROPHETIC GLORY</div>
                                    <h3>6-Year Old Healed from Cerebral Palsy</h3>
                                </div>
                                <div class="wonder-media">
                                    <img src="https://via.placeholder.com/600x400/1a3a6b/ffd700?text=Cerebral+Palsy+Healing" alt="Cerebral Palsy Healing" class="wonder-image">
                                </div>
