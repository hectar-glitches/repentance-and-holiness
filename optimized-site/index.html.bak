<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Jesus is LORD Radio - Broadcasting Live from Nakuru, Kenya. Preparing The Way For The Return of The Messiah!">
    <title>Welcome To Jesus Is LORD Radio</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/hubot-sans@5.0.0/index.min.css">
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="logo-section">
                    <img src="https://static.wixstatic.com/media/a5f063_8caa1453b6ec4d0cb0016b8d0036b75d~mv2.png/v1/fill/w_114,h_106,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/a5f063_8caa1453b6ec4d0cb0016b8d0036b75d~mv2.png" alt="Jesus is LORD Radio Logo" class="logo-image">
                    <div class="logo">
                        <span class="logo-text">Jesus is LORD</span>
                        <span class="logo-subtitle">Radio</span>
                    </div>
                </div>
                <nav class="nav">
                    <a href="index.html" class="nav-link active">Home</a>
                    <a href="about.html" class="nav-link">Jesusislordradio.org</a>
                    <a href="library.html" class="nav-link">Library Of Messages</a>
                    <a href="prophecies.html" class="nav-link">Prophecies</a>
                    <a href="testimonies.html" class="nav-link">Healing Testimonies</a>
                    <a href="social-media.html" class="nav-link">Connect With Us</a>
                </nav>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <h3 class="hero-title">Welcome To Jesus Is LORD Radio</h3>
                <p class="hero-subtitle">Preparing The Way For The Return of The Messiah!</p>
                <p class="hero-location">Broadcasting Live From Nakuru, Kenya</p>
                
                <!-- Frequencies Row -->
                <div style="display: flex; justify-content: center; align-items: center; gap: 20px; margin-top: 40px;">
                    <span class="frequency">105.3FM</span>
                    <span class="frequency-divider" style="color: #ffd700; font-size: 1.5rem;">&</span>
                    <span class="frequency">105.9FM</span>
                </div>

                <!-- Live Broadcast Player Row -->
                <div style="display: flex; justify-content: center; margin-top: 30px;">
                    <div style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); padding: 20px 30px; border-radius: 12px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3); border: 2px solid #ffd700; max-width: 400px; width: 100%;">
                        <span style="color: #ffd700; font-size: 1em; font-weight: bold; display: block; margin-bottom: 12px; text-transform: uppercase; text-align: center;">🎙️ Live Broadcast</span>
                        <audio id="radioPlayer" controls preload="none" style="width: 100%; height: 40px; border-radius: 20px; outline: none; margin-bottom: 8px;">
                            <source src="https://jesus-is-lord-radio.radioca.st/stream" type="audio/mpeg">
                            Your browser does not support the audio element.
                        </audio>
                        <span style="color: #fff; font-size: 0.8em; opacity: 0.85; display: block; text-align: center;">▶️ Click play to listen live</span>
                    </div>
                </div>

                <script>
                    // Handle radio stream playback
                    const radioPlayer = document.getElementById('radioPlayer');
                    
                    radioPlayer.addEventListener('error', function(e) {
                        console.error('Audio error:', e);
                        // Try to reload the stream
                        this.load();
                    });
                    
                    // Ensure proper loading for live streams
                    radioPlayer.addEventListener('play', function() {
                        if (this.readyState < 3) {
                            this.load();
                        }
                    });
                </script>

                <!-- Wonders Carousel -->
                <div class="wonders-carousel">
                    <h2 class="carousel-title">Mighty Wonders & Miracles</h2>
                    <div class="carousel-container">
                        <div class="carousel-wrapper">
                            <div class="carousel-track">
                            <div class="carousel-slide">
                                <div class="wonder-header">
                                    <div class="wonder-badge">SHOCK & AWE</div>
                                    <h3>The Cloud of God Descends</h3>
                                </div>
                                <div class="wonder-media">
                                    <img src="https://live-tag.creatopy.net/designs/50k866k/embed/standard/media/425a66bd04c4975ee7ff8622f1d8e7e6.jpg" 
                                         srcset="https://live-tag.creatopy.net/designs/50k866k/embed/standard/media/425a66bd04c4975ee7ff8622f1d8e7e62x.jpg 2x"
                                         alt="Cloud of God Descends" class="wonder-image">
                                </div>
                                <p class="wonder-description">The Mightiest Prophet calls down the Cloud of Glory from Heaven</p>
                                <span class="wonder-location">📍 Kisumu, Kenya</span>
                            </div>
                            <div class="carousel-slide">
                                <div class="wonder-header">
                                    <div class="wonder-badge">HEAVEN OPENED</div>
                                    <h3>Instant Rain Released</h3>
                                </div>
                                <div class="wonder-media">
                                    <img class="slideshow" src="https://pub-9f92551086574e82abebdc7b9c83cf92.r2.dev/Rain-Slide/Slide-4m.jpg" alt="Your network is unstable. Please refresh the page." style="width: 100%; height: auto;">
                                </div>
                                <p class="wonder-description">Prophet commands Heaven to open and instant rain pours down</p>
                                <span class="wonder-location">📍 Albert-Park, Suva</span>
                            </div>
                            <div class="carousel-slide">
                                <div class="wonder-header">
                                    <div class="wonder-badge">DIVINE GLORY</div>
                                    <h3>God points to the Prophet in broad daylight</h3>
                                </div>
                                <div class="wonder-media">
                                    <div class="bs-image image-crop retina" id="e_942" style="--retina-src: url(&quot;https://live-tag.creatopy.net/designs/0r3qgl0/embed/standard/media/3d339530a0db6814f03c6b9fabf635102x.jpg&quot;); background-image: url(&quot;https://live-tag.creatopy.net/designs/0r3qgl0/embed/standard/media/3d339530a0db6814f03c6b9fabf63510.jpg&quot;); background-position: 0px 50%; opacity: 1; width: 100%; height: 400px; background-size: cover;"></div>
                                </div>
                                <p class="wonder-description">Heaven opens and points directly at the Mightiest Prophet</p>
                                <span class="wonder-location">📍 Central Park, Kenya</span>
                            </div>
